<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:padding="8dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_so_1"
            android:textSize="16sp"
            android:textColor="#1C28D0"
            android:layout_marginEnd="8dp">
        </TextView>
        <EditText
            android:id="@+id/edtSo1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:hint="@string/hint_nhap_so"
            android:inputType="numberSigned|numberDecimal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
        </EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:padding="8dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_so_2"
            android:textSize="16sp"
            android:textColor="#1C28D0"
            android:layout_marginEnd="8dp">
        </TextView>

        <EditText
            android:id="@+id/edtSo2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:hint="@string/hint_nhap_so"
            android:inputType="numberSigned|numberDecimal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"></EditText>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnCong"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:minWidth="56dp"
            android:layout_margin="4dp"
            android:text="+"
            android:textSize="24sp"
            android:textStyle="bold">
        </Button>

        <Button
            android:id="@+id/btnTru"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:minWidth="56dp"
            android:layout_margin="4dp"
            android:text="-"
            android:textSize="24sp"
            android:textStyle="bold">
        </Button>

        <Button
            android:id="@+id/btnNhan"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:minWidth="56dp"
            android:layout_margin="4dp"
            android:text="*"
            android:textSize="24sp"
            android:textStyle="bold">
            
        </Button>

        <Button
            android:id="@+id/btnChia"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:minWidth="56dp"
            android:layout_margin="4dp"
            android:text="/"
            android:textSize="24sp"
            android:textStyle="bold">

        </Button>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:padding="8dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_ket_qua"
            android:textSize="16sp"
            android:textColor="#1C28D0"
            android:layout_marginEnd="8dp">
        </TextView>
        <EditText
            android:id="@+id/edtKetQua"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:hint="@string/hint_ket_qua"
            android:inputType="none"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:enabled="false">
        </EditText>
    </LinearLayout>
</LinearLayout>